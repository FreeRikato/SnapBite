{
  "name": "SnapBite",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "ci": "turbo run ci",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:frontend": "turbo run test --filter=frontend",
    "test:backend": "turbo run test --filter=serverless-backend",
    "test:serverless-backend": "turbo run test --filter=serverless-backend",
    "test:backend_serverless": "turbo run test --filter=serverless-backend",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:frontend": "turbo run check-types --filter=frontend",
    "check-types:backend": "turbo run check-types --filter=serverless-backend",
    "check-types:serverless-backend": "turbo run check-types --filter=serverless-backend",
    "check-types:backend_serverless": "turbo run check-types --filter=serverless-backend",
    "cf-typegen": "turbo run cf-typegen --filter=serverless-backend"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
